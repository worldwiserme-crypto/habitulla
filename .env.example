# ═══════════════════════════════════════════════════════
# TELEGRAM BOT
# ═══════════════════════════════════════════════════════
BOT_TOKEN=your_telegram_bot_token_from_botfather

# ═══════════════════════════════════════════════════════
# GOOGLE GEMINI
# ═══════════════════════════════════════════════════════
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# ═══════════════════════════════════════════════════════
# SUPABASE (PostgreSQL)
# ═══════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ═══════════════════════════════════════════════════════
# TIMEZONE & SCHEDULING
# ═══════════════════════════════════════════════════════
TIMEZONE=Asia/Tashkent

# Daily summary (21:00 by default)
DAILY_REMINDER_HOUR=21
DAILY_REMINDER_MINUTE=0

# Weekly report (Sunday = 6, 20:00)
WEEKLY_REPORT_WEEKDAY=6
WEEKLY_REPORT_HOUR=20

# Monthly report (1st day of month, 09:00)
MONTHLY_REPORT_DAY=1
MONTHLY_REPORT_HOUR=9

# ═══════════════════════════════════════════════════════
# ADMIN ACCESS
# ═══════════════════════════════════════════════════════
# Comma-separated Telegram user IDs (can use /admin)
ADMIN_IDS=123456789

# Private group where receipts are forwarded for approval
# Bot MUST be added as admin in this group
# Get group_id by adding @username_to_id_bot temporarily
ADMIN_GROUP_ID=-1001234567890

# ═══════════════════════════════════════════════════════
# SUBSCRIPTION PLANS (manual payment via Click/Payme/card)
# ═══════════════════════════════════════════════════════
PRICE_1_MONTH=50000
PRICE_3_MONTHS=135000
PRICE_6_MONTHS=250000

# Payment details shown to users
PAYMENT_CARD_NUMBER=8600 1234 5678 9012
PAYMENT_CARD_HOLDER=ISMINGIZ FAMILIYANGIZ
PAYMENT_CLICK_PHONE=+998901234567
PAYMENT_PAYME_PHONE=+998901234567

# ═══════════════════════════════════════════════════════
# FREE TIER LIMITS
# ═══════════════════════════════════════════════════════
FREE_DAILY_LOG_LIMIT=10
FREE_REPORT_MAX_DAYS=7

# ═══════════════════════════════════════════════════════
# RATE LIMITING (anti-spam)
# ═══════════════════════════════════════════════════════
RATE_LIMIT_MESSAGES_PER_MINUTE=20

# ═══════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════
# DEPLOYMENT (leave empty for polling mode)
# ═══════════════════════════════════════════════════════
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
